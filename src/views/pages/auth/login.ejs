<%- include('../../partials/header') %>

<div style="max-width: 300px; margin: 50px auto; border: 1px solid #ccc; padding: 20px;">
    <h2>Logowanie</h2>
    <form action="/auth/login" method="POST">
        <label>Użytkownik:</label><br>
        <input type="text" name="username" style="width: 100%; margin-bottom: 10px;" required><br>
        
        <label>Hasło:</label><br>
        <input type="password" name="password" style="width: 100%; margin-bottom: 15px;" required><br>
        
        <button type="submit" style="width: 100%;">Zaloguj</button>
    </form>
    <hr>
    <p style="font-size: 0.8em;">Nie masz konta? <a href="/auth/register">Zarejestruj się</a></p>
</div>

<%- include('../../partials/footer') %>